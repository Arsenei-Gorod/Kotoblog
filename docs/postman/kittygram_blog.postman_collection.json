    {
      "name": "List Blog Posts",
      "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test(\"Status code is 200\", function () {", "    pm.response.to.have.status(200);", "});"]}}],
      "request": {"method": "GET", "header": [], "url": "{{base_url}}/api/posts/"}
    },
    {
      "name": "Get Blog Post Detail",
      "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test(\"Status code is 200\", function () {", "    pm.response.to.have.status(200);", "});"]}}],
      "request": {"method": "GET", "header": [], "url": "{{base_url}}/api/posts/{{post_id}}/"}
    },
