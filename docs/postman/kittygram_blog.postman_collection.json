        "method": "POST",
        "header": [
          {"key": "Authorization", "value": "Bearer {{admin_access_token}}"},
          {"key": "Content-Type", "value": "application/json"}
        ],
        "url": "{{base_url}}/api/categories/",
        "body": {"mode": "raw", "raw": "{\"name\":\"Postman category {{$timestamp}}\",\"slug\":\"postman-category-{{$timestamp}}\",\"description\":\"Категория для проверки Postman\"}"}
      }
    },
    {
      "name": "List Categories",
      "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test(\"Status code is 200\", function () {", "    pm.response.to.have.status(200);", "});"]}}],
      "request": {"method": "GET", "header": [], "url": "{{base_url}}/api/categories/"}
    },
    {
      "name": "Create Tag",
      "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test(\"Status code is 201\", function () {", "    pm.response.to.have.status(201);", "});", "const json = pm.response.json();", "pm.collectionVariables.set(\"tag_id\", json.id);", "pm.collectionVariables.set(\"tag_slug\", json.slug);"]}}],
      "request": {
        "method": "POST",
        "header": [
          {"key": "Authorization", "value": "Bearer {{admin_access_token}}"},
          {"key": "Content-Type", "value": "application/json"}
