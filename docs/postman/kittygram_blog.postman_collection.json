    {
      "name": "Create Comment",
      "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test(\"Status code is 201\", function () {", "    pm.response.to.have.status(201);", "});", "const json = pm.response.json();", "pm.collectionVariables.set(\"comment_id\", json.id);"]}}],
      "request": {
