{
  "info": {
    "name": "Kittygram Blog API",
    "description": "Проверочная коллекция для REST API-сервиса котоблога Kittygram Blog.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "base_url", "value": "http://localhost"},
    {"key": "access_token", "value": ""},
    {"key": "refresh_token", "value": ""},
    {"key": "admin_access_token", "value": ""},
    {"key": "second_access_token", "value": ""},
    {"key": "username", "value": "arseniy"},
    {"key": "password", "value": "StrongPass123"},
    {"key": "second_username", "value": "ivan"},
    {"key": "second_password", "value": "StrongPass123"},
    {"key": "admin_username", "value": "admin"},
    {"key": "admin_password", "value": "AdminPass123"},
    {"key": "cat_id", "value": ""},
    {"key": "post_id", "value": ""},
    {"key": "comment_id", "value": ""},
    {"key": "category_id", "value": ""},
    {"key": "tag_id", "value": ""},
    {"key": "category_slug", "value": ""},
    {"key": "tag_slug", "value": ""}
  ],
  "item": [
    {
      "name": "Register User",
      "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test(\"Status code is 201\", function () {", "    pm.response.to.have.status(201);", "});"]}}],
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "url": "{{base_url}}/api/auth/users/",
        "body": {"mode": "raw", "raw": "{\"username\":\"{{username}}\",\"password\":\"{{password}}\"}"}
      }
    },
    {
      "name": "Create JWT Token",
      "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test(\"Status code is 200\", function () {", "    pm.response.to.have.status(200);", "});", "const json = pm.response.json();", "pm.collectionVariables.set(\"access_token\", json.access);", "pm.collectionVariables.set(\"refresh_token\", json.refresh);"]}}],
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "url": "{{base_url}}/api/auth/jwt/create/",
        "body": {"mode": "raw", "raw": "{\"username\":\"{{username}}\",\"password\":\"{{password}}\"}"}
      }
    },
    {
      "name": "Refresh JWT Token",
      "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test(\"Status code is 200\", function () {", "    pm.response.to.have.status(200);", "});", "const json = pm.response.json();", "pm.collectionVariables.set(\"access_token\", json.access);"]}}],
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "url": "{{base_url}}/api/auth/jwt/refresh/",
        "body": {"mode": "raw", "raw": "{\"refresh\":\"{{refresh_token}}\"}"}
      }
    },
    {
      "name": "Verify JWT Token",
      "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test(\"Status code is 200\", function () {", "    pm.response.to.have.status(200);", "});"]}}],
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "url": "{{base_url}}/api/auth/jwt/verify/",
        "body": {"mode": "raw", "raw": "{\"token\":\"{{access_token}}\"}"}
      }
    },
    {
      "name": "Get Current User",
      "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test(\"Status code is 200\", function () {", "    pm.response.to.have.status(200);", "});"]}}],
      "request": {
        "method": "GET",
        "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
        "url": "{{base_url}}/api/auth/users/me/"
      }
    },
    {
      "name": "Create Admin JWT Token",
      "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test(\"Status code is 200\", function () {", "    pm.response.to.have.status(200);", "});", "const json = pm.response.json();", "pm.collectionVariables.set(\"admin_access_token\", json.access);"]}}],
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "url": "{{base_url}}/api/auth/jwt/create/",
        "body": {"mode": "raw", "raw": "{\"username\":\"{{admin_username}}\",\"password\":\"{{admin_password}}\"}"}
      }
    },
    {
      "name": "Create Cat",
      "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test(\"Status code is 201\", function () {", "    pm.response.to.have.status(201);", "});", "const json = pm.response.json();", "pm.collectionVariables.set(\"cat_id\", json.id);"]}}],
      "request": {
        "method": "POST",
        "header": [
          {"key": "Authorization", "value": "Bearer {{access_token}}"},
          {"key": "Content-Type", "value": "application/json"}
        ],
        "url": "{{base_url}}/api/cats/",
        "body": {"mode": "raw", "raw": "{\"name\":\"Мурка\",\"birth_year\":2021,\"breed\":\"Сибирская\",\"color\":\"серая\",\"description\":\"Кошка автора котоблога\"}"}
      }
    },
    {
      "name": "List Cats",
      "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test(\"Status code is 200\", function () {", "    pm.response.to.have.status(200);", "});"]}}],
      "request": {"method": "GET", "header": [], "url": "{{base_url}}/api/cats/"}
    },
    {
      "name": "Get Cat Detail",
      "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test(\"Status code is 200\", function () {", "    pm.response.to.have.status(200);", "});"]}}],
      "request": {"method": "GET", "header": [], "url": "{{base_url}}/api/cats/{{cat_id}}/"}
    },
    {
      "name": "Patch Own Cat",
      "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test(\"Status code is 200\", function () {", "    pm.response.to.have.status(200);", "});"]}}],
      "request": {
        "method": "PATCH",
        "header": [
          {"key": "Authorization", "value": "Bearer {{access_token}}"},
          {"key": "Content-Type", "value": "application/json"}
        ],
        "url": "{{base_url}}/api/cats/{{cat_id}}/",
        "body": {"mode": "raw", "raw": "{\"color\":\"серая с белым\"}"}
      }
    },
    {
      "name": "Create Category",
      "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test(\"Status code is 201\", function () {", "    pm.response.to.have.status(201);", "});", "const json = pm.response.json();", "pm.collectionVariables.set(\"category_id\", json.id);", "pm.collectionVariables.set(\"category_slug\", json.slug);"]}}],
