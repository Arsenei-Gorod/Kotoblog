        "url": "{{base_url}}/api/tags/",
        "body": {"mode": "raw", "raw": "{\"name\":\"postman-tag-{{$timestamp}}\",\"slug\":\"postman-tag-{{$timestamp}}\"}"}
      }
    },
    {
      "name": "List Tags",
      "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test(\"Status code is 200\", function () {", "    pm.response.to.have.status(200);", "});"]}}],
      "request": {"method": "GET", "header": [], "url": "{{base_url}}/api/tags/"}
    },
    {
      "name": "Create Blog Post",
      "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test(\"Status code is 201\", function () {", "    pm.response.to.have.status(201);", "});", "const json = pm.response.json();", "pm.collectionVariables.set(\"post_id\", json.id);"]}}],
      "request": {
        "method": "POST",
